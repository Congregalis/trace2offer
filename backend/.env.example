# Trace2Offer backend server
PORT=8080
T2O_DATA_DIR=./data

# Agent runtime storage
T2O_AGENT_SESSION_DATA=./data/sessions
T2O_AGENT_MEMORY_DATA=./data/agent_memory.json
T2O_AGENT_SETTINGS_DATA=./data/agent_runtime_config.json
T2O_AGENT_USER_PROFILE_DATA=./data/user_profile.json
T2O_AGENT_RESUME_DATA_DIR=./data/resume

# OpenAI provider
OPENAI_API_KEY=your_openai_api_key
T2O_AGENT_MODEL=gpt-5.2
# 可选: responses | chat_completions
T2O_OPENAI_API_FORMAT=responses
# 可选自定义。留空时按 T2O_OPENAI_API_FORMAT 自动选择:
# responses -> https://api.openai.com/v1/responses
# chat_completions -> https://api.openai.com/v1/chat/completions
T2O_OPENAI_BASE_URL=
T2O_OPENAI_TIMEOUT_SECONDS=60
# 备面（RAG）调用模型的超时时间，避免长输出在 60 秒卡死
T2O_PREP_OPENAI_TIMEOUT_SECONDS=180

# Agent loop behavior
T2O_AGENT_MAX_STEPS=6
T2O_AGENT_SYSTEM_PROMPT=

# Prep (RAG / Embedding)
T2O_PREP_ENABLED=true
T2O_PREP_DEFAULT_QUESTION_COUNT=8
# 默认 embedding model（可替换成任意兼容 TEI / HF Inference 的 embedding 模型）
T2O_PREP_HF_MODEL=intfloat/multilingual-e5-small
# 如果你本地跑 TEI，把地址填到这里（示例: http://127.0.0.1:8081/embed）
T2O_PREP_HF_BASE_URL=
# 仅当未配置 T2O_PREP_HF_BASE_URL（走 Hugging Face Inference API）时需要
T2O_PREP_HF_API_KEY=

# Resume PDF extractor
# 默认使用 legacy（纯 Go 提取）
# 如需启用 Docling，推荐用 uv 虚拟环境安装：
#   uv venv .venv
#   uv pip install --python .venv/bin/python docling
# 然后把提取器切到 docling，并指定 venv python 路径：
#   T2O_RESUME_PDF_EXTRACTOR=docling
#   T2O_DOCLING_PYTHON_BIN=./.venv/bin/python
T2O_RESUME_PDF_EXTRACTOR=legacy
T2O_DOCLING_PYTHON_BIN=python3
T2O_DOCLING_TIMEOUT_SECONDS=120
